# Virtual environments (the OGBench env is large)
.venv-ogbench/
.venv/
venv/
env/

# Raw per-seed results are regenerated by `make full`; keep the small summaries.
results/*/*/*/seed*.json
results/*/trajectories/
!results/master_table.md
!results/master_table.json
!results/*/gain_sweep.json
!results/*/certificate.json

# Redundant large gif previews; the small mp4 clips are committed and are what the site uses.
clips/*/*.gif
website/static/clips/*.gif
docs/static/clips/*.gif

# Scratch
_mkpdf.sh
*.log

__pycache__/
*.pyc
.ipynb_checkpoints/
.DS_Store
*.egg-info/
build/
dist/
